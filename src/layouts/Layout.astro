---
import '../styles/global.css'
import { sections } from '../lib/sections.js'

const { title = 'Bananapedia', description = 'All things bananas: history, science, culture, music, media, merch, jokes, and facts.' } = Astro.props
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍌</text></svg>" />
  </head>
  <body class="bg-yellow-50 text-gray-900 min-h-screen flex flex-col">
    <nav class="bg-yellow-400 border-b-4 border-yellow-500 shadow-sm">
      <div class="max-w-6xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-x-8 gap-y-2">
        <a href="/" class="text-2xl font-black tracking-tight text-yellow-950">🍌 Bananapedia</a>
        <div class="flex flex-wrap gap-x-5 gap-y-1 text-sm font-bold text-yellow-950">
          {sections.map((s) => (
            <a href={'/' + s.slug + '/'} class="hover:underline">{s.emoji} {s.name}</a>
          ))}
        </div>
      </div>
    </nav>
    <div class="flex-1">
      <slot />
    </div>
    <footer class="mt-16 py-8 text-center text-sm text-yellow-800/70">
      Bananapedia — the whole bunch, in one place. 🍌
    </footer>
  </body>
</html>
