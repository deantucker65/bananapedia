---
import Layout from '../../layouts/Layout.astro'
import { sections } from '../../lib/sections.js'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  return articles.map((a) => ({
    params: { section: a.data.section, slug: a.id },
    props: { article: a },
  }))
}

const { article } = Astro.props
const meta = sections.find((s) => s.slug === article.data.section)
const { Content } = await render(article)
---
<Layout title={article.data.title + ' — Bananapedia'} description={article.data.description}>
  <main class="max-w-3xl mx-auto px-6 py-12">
    <a href={'/' + meta.slug + '/'} class="text-yellow-700 font-bold text-sm hover:underline">
      ← Back to {meta.emoji} {meta.name}
    </a>
    <article class="bg-white rounded-2xl border-2 border-yellow-200 p-8 sm:p-10 mt-4">
      <h1 class="text-3xl sm:text-4xl font-black text-yellow-950 mb-2">{article.data.title}</h1>
      <p class="text-gray-500 italic mb-8">{article.data.description}</p>
      <div class="prose prose-yellow max-w-none">
        <Content />
      </div>
    </article>
  </main>
</Layout>
